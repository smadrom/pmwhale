{
  "name": "pmwhale-ui",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run build",
    "licenses": "license-checker-rseidelsohn --production --excludePrivatePackages --plainVertical --out THIRD_PARTY_LICENSES.txt",
    "licenses:allowlist": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow 'MIT;ISC;Apache-2.0;Apache-2.0*;BSD-3-Clause;0BSD;MIT AND ISC'",
    "preview": "vite preview",
    "start": "bun server.ts"
  },
  "dependencies": {
    "@tremor/react": "3.18.7",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.5.4",
    "license-checker-rseidelsohn": "4.4.2",
    "postcss": "8.5.19",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.2",
    "vite": "6.4.3"
  }
}
