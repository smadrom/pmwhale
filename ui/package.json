{
  "name": "pmwhale-ui",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run build",
    "licenses": "license-checker-rseidelsohn --production --excludePrivatePackages --plainVertical --out THIRD_PARTY_LICENSES.txt",
    "licenses:allowlist": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow 'MIT;ISC;Apache-2.0;Apache-2.0*;BSD-3-Clause;0BSD;MIT AND ISC'",
    "preview": "vite preview",
    "start": "bun server.ts"
  },
  "dependencies": {
    "@tremor/react": "3.18.7",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.4",
    "license-checker-rseidelsohn": "5.0.1",
    "postcss": "8.5.20",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
